{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "A beautiful desktop Pomodoro timer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.pomodoro.timer",
    "productName": "番茄钟",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
